    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "smoke": "node scripts/smoke.mjs",
    "inspect": "npx -y @modelcontextprotocol/inspector node src/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lilagents",
    "seo",
    "geo",
    "aeo",
    "ai-visibility",
    "agent-tools"
  ],
