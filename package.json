  "homepage": "https://lilagents.com/mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lilAgents/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/lilAgents/mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  }
}
